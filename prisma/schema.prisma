generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  UTILISATEUR
  ADMIN
}

enum CollecteType {
  AIR
  METEO
  POPULATION
}

enum CollecteStatut {
  SUCCESS
  ERROR
}

enum AlertType {
  AIR
  METEO
}

enum AlertPalier {
  AIR_MOYEN
  AIR_MAUVAIS
  AIR_TRES_MAUVAIS
  METEO_SEVERE
}

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  username       String         @unique
  nom            String
  prenom         String
  password       String
  role           Role           @default(UTILISATEUR)
  adressePostale String?
  communeId      Int?
  commune        Commune?       @relation(fields: [communeId], references: [id], onDelete: SetNull)
  estSuspendu    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  favoris        Favori[]
  topics         Topic[]
  comments       Comment[]
  votes          Vote[]
  notifications  Notification[]
  suspensions    SuspensionLog[] @relation("UserSuspensions")
  adminActions   SuspensionLog[] @relation("AdminActions")
  alerts         Alert[]
  alertLogs      AlertLog[]
  manualAlerts   ManualAlert[]
}

model Commune {
  id          Int       @id @default(autoincrement())
  nom         String
  codePostal  String
  codeInsee   String    @unique
  population  Int?
  latitude    Decimal
  longitude   Decimal
  active      Boolean   @default(false)
  activatedAt DateTime?

  donneesAir      DonneeAir[]
  donneesMeteo    DonneeMeteo[]
  favoris         Favori[]
  usersReference  User[]
  alerts          Alert[]
  alertLogs       AlertLog[]
  manualAlerts    ManualAlert[]

  @@index([nom])
  @@index([codePostal])
}

model DonneeAir {
  id            Int      @id @default(autoincrement())
  communeId     Int
  ozone         Float?
  co            Float?
  pm25          Float?
  pm10          Float?
  indiceQualite Int?
  dateHeure     DateTime

  commune Commune @relation(fields: [communeId], references: [id])

  @@index([communeId, dateHeure])
}

model DonneeMeteo {
  id          Int      @id @default(autoincrement())
  communeId   Int
  temperature Float?
  pression    Float?
  humidite    Float?
  meteoCiel   String?
  weatherCode Int?
  vitesseVent Float?
  dateHeure   DateTime

  commune Commune @relation(fields: [communeId], references: [id])

  @@index([communeId, dateHeure])
}

model Favori {
  id        Int      @id @default(autoincrement())
  userId    Int
  communeId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commune   Commune  @relation(fields: [communeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, communeId])
}

model LogCollecte {
  id               Int            @id @default(autoincrement())
  type             CollecteType
  statut           CollecteStatut
  communesTraitees Int
  communesErreur   Int            @default(0)
  dureeMs          Int
  dateExecution    DateTime       @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  topics    Topic[]
}

model Topic {
  id         Int       @id @default(autoincrement())
  title      String
  content    String
  userId     Int
  categoryId Int?
  status     String    @default("visible")
  isClosed   Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments   Comment[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  userId    Int
  topicId   Int
  parentId  Int?
  status    String    @default("visible")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic    Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Comment[] @relation("CommentTree")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  message   String
  reason    String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vote {
  id         Int      @id @default(autoincrement())
  userId     Int
  targetType String
  targetId   Int
  value      Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
}

model SuspensionLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  adminId   Int
  action    String
  motif     String?
  createdAt DateTime @default(now())

  user  User @relation("UserSuspensions", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("AdminActions", fields: [adminId], references: [id])
}

model Alert {
  id                Int          @id @default(autoincrement())
  userId            Int
  communeId         Int
  type              AlertType
  palier            AlertPalier
  active            Boolean      @default(true)
  wasUnderThreshold Boolean      @default(true)
  lastTriggeredAt   DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commune Commune    @relation(fields: [communeId], references: [id], onDelete: Cascade)
  logs    AlertLog[]

  @@unique([userId, communeId, type])
}

model AlertLog {
  id               Int          @id @default(autoincrement())
  alertId          Int?
  userId           Int
  communeId        Int
  type             AlertType
  palier           AlertPalier?
  valeurMesuree    Float
  seuilDeclenche   Float
  unite            String
  officielle       Boolean      @default(false)
  emailSent        Boolean      @default(false)
  notificationSent Boolean      @default(false)
  createdAt        DateTime     @default(now())

  alert   Alert?  @relation(fields: [alertId], references: [id], onDelete: SetNull)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commune Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)
}

model ManualAlert {
  id          Int          @id @default(autoincrement())
  communeId   Int
  palier      AlertPalier
  message     String?
  createdBy   Int
  expiresAt   DateTime
  closedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  commune Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)
  admin   User    @relation(fields: [createdBy], references: [id])

  @@index([communeId])
}
